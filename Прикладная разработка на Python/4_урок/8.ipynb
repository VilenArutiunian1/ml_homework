   "source": [
    "import numpy as np\n",
    "\n",
    "def normalize(X: np.ndarray) -> np.ndarray:\n",
    "    min_vals = np.min(X, axis=0)\n",
    "    max_vals = np.max(X, axis=0)\n",
    "    return (X - min_vals) / (max_vals - min_vals)\n"
   ]
  },
